SCHEMAS=./schemas
LIB_MODULES=./karrio/schemas/dhl_freight
find "${LIB_MODULES}" -name "*.py" -exec rm -r {} \;
touch "${LIB_MODULES}/__init__.py"

generate_schema() {
    echo "Generating $1..."
    "${ROOT}/bin/cli" codegen generate "$1" "$2" --no-nice-property-names
}

# JSON schemas for shipment booking (sendtransportinstruction)
# Note: DHL Freight does not publish OpenAPI/Swagger. Schemas under ./schemas
# are hand-derived from the Product Manual PDF and the Sandbox Postman
# collection — see PRD.md for the derivation process.
generate_schema "${SCHEMAS}/shipping_request.json"  "${LIB_MODULES}/shipping_request.py"
generate_schema "${SCHEMAS}/shipping_response.json" "${LIB_MODULES}/shipping_response.py"
generate_schema "${SCHEMAS}/error_response.json"    "${LIB_MODULES}/error_response.py"

# DHL Group Unified Tracking API (UTAPI) response — /track/shipments
generate_schema "${SCHEMAS}/tracking_response.json" "${LIB_MODULES}/tracking_response.py"
