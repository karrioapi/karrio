{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Karrio Helm chart values",
  "description": "Schema derived from charts/karrio/values.yaml. Validated by `helm lint` and `helm install` so bad value sets fail before hitting the API server.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "object" }
    },
    "existingSecret": { "type": "string" },
    "dashboardUrl": { "type": "string" },
    "karrioPublicUrl": { "type": "string" },
    "image": {
      "type": "object",
      "required": ["server", "dashboard"],
      "properties": {
        "server": { "$ref": "#/definitions/image" },
        "dashboard": { "$ref": "#/definitions/image" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0 },
        "resources": { "$ref": "#/definitions/resources" },
        "livenessProbe": { "$ref": "#/definitions/probe" },
        "readinessProbe": { "$ref": "#/definitions/probe" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "autoscaling": { "$ref": "#/definitions/autoscaling" },
        "podDisruptionBudget": { "$ref": "#/definitions/pdb" }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0 },
        "resources": { "$ref": "#/definitions/resources" },
        "livenessProbe": { "$ref": "#/definitions/probe" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "podDisruptionBudget": { "$ref": "#/definitions/pdb" },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": {
              "type": ["integer", "null"],
              "minimum": 1,
              "maximum": 100
            },
            "targetMetricName": { "type": "string" },
            "targetValue": { "type": ["string", "number"] }
          }
        }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0 },
        "resources": { "$ref": "#/definitions/resources" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "api": {
          "type": "object",
          "properties": { "host": { "type": "string" } }
        },
        "dashboard": {
          "type": "object",
          "properties": { "host": { "type": "string" } }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretName": { "type": "string" },
              "hosts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "secretKey": { "type": "string" },
        "jwtSecret": { "type": "string" },
        "debugMode": { "type": "string" },
        "useHttps": { "type": "string" },
        "detachedWorker": { "type": "string" },
        "enableAllPlugins": { "type": "string" }
      }
    },
    "database": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": ["integer", "string"] },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "port": { "type": ["integer", "string"] }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  },
  "definitions": {
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": { "type": "object" },
        "limits": { "type": "object" }
      }
    },
    "probe": {
      "type": "object",
      "properties": {
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    }
  }
}
