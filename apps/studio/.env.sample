# Karrio backend (GraphQL + REST) — reused by @karrio/hooks
KARRIO_API=http://localhost:5002
NEXT_PUBLIC_KARRIO_PUBLIC_URL=http://localhost:5002

# Studio server session (httpOnly cookie signing)
STUDIO_SESSION_SECRET=change-me-in-production

# Studio-native database (Postgres in prod, local for dev)
DATABASE_URL=postgres://karrio:karrio@localhost:5432/karrio_studio

# Optional: AI Assistant / agents (Claude API)
ANTHROPIC_API_KEY=
